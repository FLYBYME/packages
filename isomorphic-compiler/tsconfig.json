{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "composite": true,
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@flybyme/isomorphic-core": ["../isomorphic-core/src/index"],
      "@flybyme/isomorphic-fs": ["../isomorphic-fs/src/index"],
      "@flybyme/isomorphic-database": ["../isomorphic-database/src/index"],
      "@flybyme/isomorphic-mesh": ["../isomorphic-mesh/src/index"],
      "@flybyme/isomorphic-ui": ["../isomorphic-ui/src/index"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../isomorphic-core" },
    { "path": "../isomorphic-fs" },
    { "path": "../isomorphic-database" },
    { "path": "../isomorphic-mesh" },
    { "path": "../isomorphic-ui" }
  ]
}
