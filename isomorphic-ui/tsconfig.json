{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "composite": true,
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@flybyme/isomorphic-auth": ["../isomorphic-auth/src/index"],
      "@flybyme/isomorphic-core": ["../isomorphic-core/src/index"],
      "@flybyme/isomorphic-database": ["../isomorphic-database/src/index"],
      "@flybyme/isomorphic-fs": ["../isomorphic-fs/src/index"],
      "@flybyme/isomorphic-mesh": ["../isomorphic-mesh/src/index"],
      "@flybyme/isomorphic-registry": ["../isomorphic-registry/src/index"],
      "@flybyme/isomorphic-streams": ["../isomorphic-streams/src/index"],
      "@flybyme/isomorphic-resiliency": ["../isomorphic-resiliency/src/index"],
      "@flybyme/isomorphic-telemetry": ["../isomorphic-telemetry/src/index"],
      "@flybyme/isomorphic-ui": ["src/index"],
      "@flybyme/isomorphic-utils": ["../isomorphic-utils/src/index"],
      "@flybyme/isomorphic-compiler": ["../isomorphic-compiler/src/index"],
      "@flybyme/isomorphic-cdn": ["../isomorphic-cdn/src/index"],
      "@flybyme/raft-consensus": ["../raft-consensus/src/index"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../isomorphic-core"
    },
    {
      "path": "../isomorphic-mesh"
    },
    {
      "path": "../isomorphic-registry"
    },
    {
      "path": "../isomorphic-telemetry"
    }
  ]
}
