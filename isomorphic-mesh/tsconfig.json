{
  "compilerOptions": {
    "lib": [
      "ES2020",
      "DOM",
      "WebWorker"
    ],
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "rootDir": "src",
    "composite": true
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../isomorphic-core"
    }
  ]
}
