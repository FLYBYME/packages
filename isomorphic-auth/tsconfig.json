{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "composite": true,
    "rootDir": "src",
    "baseUrl": "."
  },
  "include": [
    "src/**/*"
  ],
  "references": [
    {
      "path": "../isomorphic-core"
    },
    {
      "path": "../isomorphic-database"
    },
    {
      "path": "../isomorphic-registry"
    },
    {
      "path": "../raft-consensus"
    }
  ]
}
