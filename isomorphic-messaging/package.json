{
  "name": "@flybyme/isomorphic-messaging",
  "version": "1.0.53",
  "description": "Decentralized, backpressure-aware Pub/Sub for the isomorphic mesh",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0"
  },
  "dependencies": {
    "@flybyme/isomorphic-core": "*",
    "@flybyme/isomorphic-database": "*",
    "@flybyme/isomorphic-kv": "*",
    "@flybyme/isomorphic-streams": "*",
    "nanoid": "^3.3.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@flybyme/isomorphic-core$": "<rootDir>/../isomorphic-core/src/index",
      "^@flybyme/isomorphic-streams$": "<rootDir>/../isomorphic-streams/src/index",
      "^@flybyme/isomorphic-kv$": "<rootDir>/../isomorphic-kv/src/index"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FLYBYME/mesh.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
